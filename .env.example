PORT=4000
DATABASE_URL="postgresql://snaplink:snaplink@localhost:5434/snaplink?schema=public"
JWT_SECRET="change-this-to-a-long-random-string"
# Access token lifetime. Kept short since refresh tokens now handle long sessions.
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN_DAYS=30

IMAGEKIT_PUBLIC_KEY=""
IMAGEKIT_PRIVATE_KEY=""
IMAGEKIT_URL_ENDPOINT=""

# Path to the Firebase service-account JSON (Project settings -> Service accounts
# -> Generate new private key). Defaults to ./secrets/firebase-service-account.json.
FIREBASE_SERVICE_ACCOUNT_PATH=""

# IAM user/role needs s3:PutObject (and s3:GetObject if the bucket isn't public-read).
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
AWS_S3_BUCKET=""
# Optional: CloudFront/custom domain in front of the bucket. Leave blank to use
# the bucket's default https://<bucket>.s3.<region>.amazonaws.com/<key> URL.
AWS_S3_PUBLIC_BASE_URL=""

CORS_ORIGIN="*"
